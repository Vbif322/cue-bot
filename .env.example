BOT_TOKEN=your_telegram_bot_token_here
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
NODE_ENV=development

# Admin panel
JWT_SECRET=change-this-to-a-long-random-secret
ADMIN_PORT=3000
# Публичный HTTPS-URL деплоя. Используется для ссылки одноразового входа в админку
# и как база URL вебхука Telegram (только в production).
PUBLIC_BASE_URL=https://cuebot.ru
# Секрет вебхука Telegram (production). Входит в путь вебхука и проверяется по заголовку
# X-Telegram-Bot-Api-Secret-Token. Задайте длинную случайную строку. В dev не нужен.
TELEGRAM_WEBHOOK_SECRET=change-this-to-a-long-random-secret
