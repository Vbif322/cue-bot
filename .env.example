BOT_TOKEN=your_telegram_bot_token_here
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
NODE_ENV=development

# Admin panel
JWT_SECRET=change-this-to-a-long-random-secret
ADMIN_PORT=3000

# Публичный HTTPS-URL деплоя: сайт игрока и база URL вебхука Telegram (только в production).
# Обязателен в production.
PUBLIC_BASE_URL=https://example.com
# HTTPS-URL админки (отдельный поддомен). Ссылка одноразового входа в админку (/dashboard),
# диспетчеризация статики по Host и redirect-шим в /api/auth/token. Обязателен в production.
ADMIN_BASE_URL=https://admin.example.com
# Секрет вебхука Telegram (production). Входит в путь вебхука и проверяется по заголовку
# X-Telegram-Bot-Api-Secret-Token. Задайте длинную случайную строку. В dev не нужен.
TELEGRAM_WEBHOOK_SECRET=change-this-to-a-long-random-secret

TELEGRAM_CLIENT_ID=
TELEGRAM_CLIENT_SECRET=
TELEGRAM_REDIRECT_URI=http://localhost:5173/api/app/auth/telegram/callback

BOT_UPDATE_MODE=polling

# Почта (беспарольный вход по коду). В dev можно оставить пустым SMTP_HOST —
# письма не уходят, 6-значный код печатается в консоль (jsonTransport).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Cue Bot <no-reply@example.com>
