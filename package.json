{
  "name": "cue-bot",
  "version": "1.1.0",
  "description": "",
  "homepage": "https://github.com/Vbif322/cue-bot#readme",
  "bugs": {
    "url": "https://github.com/Vbif322/cue-bot/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vbif322/cue-bot.git"
  },
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:coverage": "vitest run --coverage",
    "dev": "nodemon",
    "dev:admin": "npm run dev --prefix admin",
    "dev:all": "npm run db:up && concurrently --kill-others-on-fail -n api,web,db,login -c blue,magenta,green,blue \"nodemon\" \"node admin/node_modules/vite/bin/vite.js --config admin/vite.config.ts admin --host\" \"tsx node_modules/drizzle-kit/bin.cjs studio\" \"sleep 3 && (npm run dev:login || true)\"",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node --env-file=.env build/index.js",
    "build:admin": "npm run build --prefix admin",
    "db:up": "docker start drizzle-postgres && until docker exec drizzle-postgres pg_isready -q; do sleep 0.2; done",
    "db:up:wsl": "wsl -d Ubuntu -e bash -c \"docker start drizzle-postgres && until docker exec drizzle-postgres pg_isready -q; do sleep 0.2; done\"",
    "db:down": "docker stop drizzle-postgres",
    "db:down:wsl": "wsl -d Ubuntu -e docker stop drizzle-postgres",
    "db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx node_modules/drizzle-kit/bin.cjs migrate",
    "db:studio": "tsx node_modules/drizzle-kit/bin.cjs studio",
    "seed:de": "tsx --env-file=.env scripts/seed-double-elim.ts",
    "dev:login": "tsx --env-file=.env scripts/dev-login.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "dayjs": "^1.11.13",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.41.1",
    "hono": "^4.12.9",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testcontainers/postgresql": "^12.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.7",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "testcontainers": "^12.0.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7"
  }
}
